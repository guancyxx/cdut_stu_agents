# ====================
# LLM Configuration (Required)
# ====================
UTU_LLM_TYPE=chat.completions
UTU_LLM_MODEL=deepseek-chat
UTU_LLM_BASE_URL=https://api.deepseek.com/v1
UTU_LLM_API_KEY=your-d...here

# ====================
# Search API Configuration (Optional)
# ====================
# Enable web search: get API key from https://serper.dev/playground
# SERPER_API_KEY=your-s...here

# ====================
# Frontend Configuration
# ====================
UTU_WEBUI_PORT=8848
UTU_WEBUI_IP=0.0.0.0

# ====================
# Project-specific Configuration
# ====================
# Student code submission directory
SUBMISSION_DIR=/app/data/submissions

# Training data directory
TRAINING_DIR=/app/data/training

# Chat history directory
CHAT_HISTORY_DIR=/app/data/chat_history

# Problem data directory
PROBLEMS_DIR=/app/data/problems

# ====================
# Timezone
# ====================
TZ=Asia/Shanghai

# ====================
# Celery Auditor LLM
# ====================
XIAOMI_API_KEY=your-x...here

# ====================
# Infrastructure — host-specific (local vs remote)
# ====================
# Docker Compose service name of the PostgreSQL container
# Local: cdut-postgres  |  Remote (Alibaba Cloud): cdut-oj-postgres
LITE_DB_HOST=cdut-postgres

# Host-side path for test_case files (bind-mounted to /data/test_cases in containers)
# Local: ./data/test_cases  |  Remote (Alibaba Cloud): ./qduoj/data/backend/test_case
TEST_CASES_HOST_PATH=./data/test_cases
